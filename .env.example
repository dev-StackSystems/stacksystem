# =============================================================================
# VARIÁVEIS DE AMBIENTE — StackSystems
# =============================================================================
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite .env.local ou qualquer arquivo com segredos reais.
#
# Neon branching:
#   - Produção: branch "main" do projeto Neon
#   - Desenvolvimento: branch "dev" do projeto Neon (criar em console.neon.tech)
# =============================================================================

# Banco de dados (Neon PostgreSQL)
# Dev:  string de conexão da branch "dev"  no Neon
# Prod: string de conexão da branch "main" no Neon
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="gere-com: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# E-mail (Nodemailer)
EMAIL_HOST=""
EMAIL_PORT="587"
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM=""
