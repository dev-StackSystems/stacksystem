generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  A // Administrador
  T // Técnico
  F // Corpo Docente
}

// ─── Auth / Usuários internos ──────────────────────────
model User {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  password   String
  role       UserRole  @default(F)
  department String?
  phone      String?
  avatar     String?
  active     Boolean   @default(true)
  empresaId  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  empresa       Empresa?        @relation(fields: [empresaId], references: [id])
  accounts      Account[]
  sessions      Session[]
  segurancaLogs SegurancaUser[]
  salasCreadas  Sala[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Empresas ─────────────────────────────────────────
model Empresa {
  id          String   @id @default(cuid())
  nome        String
  cnpj        String?  @unique
  email       String?
  telefone    String?
  ativa       Boolean  @default(true)
  // Identidade visual
  cor         String?  // hex: #f97316
  logo        String?  // URL da logo
  banner      String?  // URL do banner
  // Configuração do sistema
  tipoSistema String?  // escola | treinamento | consultoria | clinica | personalizado
  descricao   String?
  anuncios    String?  // JSON: [{titulo, texto, cor}]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cursos   EmpCurso[]
  usuarios User[]
  modulos  EmpresaModulo[]
  salas    Sala[]

  @@map("empresas")
}

// ─── Módulos por empresa ───────────────────────────────
model EmpresaModulo {
  id        String  @id @default(cuid())
  empresaId String
  modulo    String  // alunos, cursos, matriculas, baixas, certificados, salas, aulas
  ativo     Boolean @default(true)

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, modulo])
  @@map("empresa_modulos")
}

// ─── Salas WebRTC ──────────────────────────────────────
model Sala {
  id              String   @id @default(cuid())
  nome            String
  codigo          String   @unique
  empresaId       String?
  criadoPorId     String
  maxParticipantes Int     @default(10)
  ativa           Boolean  @default(true)
  createdAt       DateTime @default(now())

  empresa    Empresa?    @relation(fields: [empresaId], references: [id])
  criadoPor  User        @relation(fields: [criadoPorId], references: [id])
  signal     SalaSignal?

  @@map("salas")
}

// ─── Sinalização WebRTC (HTTP polling) ────────────────
model SalaSignal {
  id         String   @id @default(cuid())
  salaId     String   @unique
  offer      String?  @db.Text
  answer     String?  @db.Text
  callerName String?
  calleeName String?
  iceCaller  String   @default("[]") @db.Text
  iceCallee  String   @default("[]") @db.Text
  updatedAt  DateTime @updatedAt

  sala Sala @relation(fields: [salaId], references: [id], onDelete: Cascade)

  @@map("sala_signals")
}

// ─── Cursos por empresa ────────────────────────────────
model EmpCurso {
  id           String  @id @default(cuid())
  empresaId    String
  nome         String
  descricao    String?
  cargaHoraria Int?
  ativo        Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  empresa      Empresa      @relation(fields: [empresaId], references: [id])
  modulos      Modulo[]
  matriculas   Matricula[]
  certificados Certificado[]

  @@map("emp_cursos")
}

// ─── Módulos ───────────────────────────────────────────
model Modulo {
  id          String   @id @default(cuid())
  empCursoId  String
  nome        String
  descricao   String?
  ordem       Int      @default(0)
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())

  empCurso EmpCurso @relation(fields: [empCursoId], references: [id])
  aulas    Aula[]

  @@map("modulos")
}

// ─── Aulas ────────────────────────────────────────────
model Aula {
  id        String   @id @default(cuid())
  moduloId  String
  nome      String
  tipo      String   @default("video") // video, online, texto, pdf
  duracao   Int?     // em minutos
  url       String?
  ordem     Int      @default(0)
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())

  modulo     Modulo          @relation(fields: [moduloId], references: [id])
  andamentos AlunoAndamento[]

  @@map("aulas")
}

// ─── Alunos ───────────────────────────────────────────
model Aluno {
  id        String    @id @default(cuid())
  nome      String
  email     String    @unique
  cpf       String?   @unique
  telefone  String?
  dataNasc  DateTime?
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  matriculas   Matricula[]
  certificados Certificado[]

  @@map("alunos")
}

// ─── Matrículas ───────────────────────────────────────
model Matricula {
  id         String   @id @default(cuid())
  alunoId    String
  empCursoId String
  status     String   @default("ativa") // ativa, concluida, cancelada
  dataInicio DateTime @default(now())
  dataFim    DateTime?
  valor      Decimal  @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  aluno      Aluno          @relation(fields: [alunoId], references: [id])
  empCurso   EmpCurso       @relation(fields: [empCursoId], references: [id])
  andamentos AlunoAndamento[]
  baixas     Baixa[]

  @@map("matriculas")
}

// ─── Andamento dos alunos ─────────────────────────────
model AlunoAndamento {
  id          String    @id @default(cuid())
  matriculaId String
  aulaId      String
  concluida   Boolean   @default(false)
  dataConc    DateTime?
  createdAt   DateTime  @default(now())

  matricula Matricula @relation(fields: [matriculaId], references: [id])
  aula      Aula      @relation(fields: [aulaId], references: [id])

  @@unique([matriculaId, aulaId])
  @@map("alunos_andamento")
}

// ─── Baixas financeiras ───────────────────────────────
model Baixa {
  id          String   @id @default(cuid())
  matriculaId String?
  descricao   String?
  valor       Decimal  @db.Decimal(10, 2)
  tipo        String   @default("mensalidade") // mensalidade, matricula, certificado, outros
  status      String   @default("pendente")    // pago, pendente, cancelado
  dataPag     DateTime?
  dataVenc    DateTime?
  createdAt   DateTime @default(now())

  matricula Matricula? @relation(fields: [matriculaId], references: [id])

  @@map("baixas")
}

// ─── Certificados ─────────────────────────────────────
model Certificado {
  id          String   @id @default(cuid())
  alunoId     String
  empCursoId  String
  codigo      String   @unique @default(cuid())
  dataEmissao DateTime @default(now())

  aluno    Aluno    @relation(fields: [alunoId], references: [id])
  empCurso EmpCurso @relation(fields: [empCursoId], references: [id])

  @@map("certificados")
}

// ─── Auditoria de segurança ───────────────────────────
model SegurancaUser {
  id        String   @id @default(cuid())
  userId    String
  acao      String   // login, logout, create_user, edit_user, etc.
  detalhes  String?
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("seguranca_user")
}
