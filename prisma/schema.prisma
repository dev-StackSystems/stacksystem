generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  A // Administrador
  T // Técnico
  F // Corpo Docente
}

// ─── Auth / Usuários internos ──────────────────────────
model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         UserRole  @default(F)
  isSuperAdmin Boolean   @default(false) // Apenas o desenvolvedor/i3 — acesso irrestrito a todas as empresas
  department   String?
  phone        String?
  avatar       String?
  active       Boolean   @default(true)
  empresaId    String?
  setorId      String?
  grupoId      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  empresa       Empresa?        @relation(fields: [empresaId], references: [id])
  setor         Setor?          @relation(fields: [setorId], references: [id])
  grupo         Grupo?          @relation(fields: [grupoId], references: [id])
  accounts      Account[]
  sessions      Session[]
  segurancaLogs SegurancaUser[]
  salasCreadas  Sala[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Empresas ─────────────────────────────────────────
model Empresa {
  id          String   @id @default(cuid())
  // Identificação (como i3: pref_nome, pref_sigla, pref_cnpj)
  nome        String
  sigla       String?  // Ex: PMSM, SEMEDUC
  cnpj        String?  @unique
  // Contato (como i3: pref_email, pref_telefone, pref_fax, pref_site)
  email       String?
  telefone    String?
  fax         String?
  site        String?
  // Endereço (como i3: pref_endereco, pref_bairro, pref_cep, pref_municipio, cod_uf)
  endereco    String?
  bairro      String?
  cep         String?
  municipio   String?
  uf          String?
  latitude    String?
  longitude   String?
  // Identidade visual (como i3: cor_topo, cor_portal, company_logo, pref_icone, pref_capa)
  cor         String?  // Cor primária hex
  cor2        String?  // Cor secundária hex
  logo        String?  // URL da logomarca
  brasao      String?  // URL do brasão/ícone oficial
  banner      String?  // URL do banner/capa
  // Configuração (como i3: nome_sistema, tipoSistema, pref_mascara)
  nomeSistema String?  // Nome da plataforma: "Portal SEMEDUC"
  tipoSistema String?  // escola | treinamento | consultoria | clinica | personalizado
  mascara     String?  // Máscara de numeração ex: ###/AAAA
  descricao   String?
  anuncios    String?  // JSON: [{titulo, texto, cor}]
  ativa       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cursos   EmpCurso[]
  usuarios User[]
  alunos   Aluno[]
  modulos  EmpresaModulo[]
  salas    Sala[]
  setores  Setor[]
  grupos   Grupo[]

  @@map("empresas")
}

// ─── Setores (departamentos da empresa) ───────────────
model Setor {
  id        String   @id @default(cuid())
  empresaId String
  nome      String
  descricao String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa  Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  modulos  SetorModulo[]
  usuarios User[]

  @@unique([empresaId, nome])
  @@map("setores")
}

model SetorModulo {
  setorId String
  modulo  String

  setor Setor @relation(fields: [setorId], references: [id], onDelete: Cascade)

  @@id([setorId, modulo])
  @@map("setor_modulos")
}

// ─── Grupos de usuários (criáveis por empresa) ────────
model Grupo {
  id        String   @id @default(cuid())
  empresaId String
  nome      String
  descricao String?
  isAdmin   Boolean  @default(false) // acesso completo aos módulos da empresa
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa  Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  modulos  GrupoModulo[]
  usuarios User[]

  @@unique([empresaId, nome])
  @@map("grupos")
}

model GrupoModulo {
  grupoId String
  modulo  String

  grupo Grupo @relation(fields: [grupoId], references: [id], onDelete: Cascade)

  @@id([grupoId, modulo])
  @@map("grupo_modulos")
}

// ─── Módulos por empresa ───────────────────────────────
model EmpresaModulo {
  id        String  @id @default(cuid())
  empresaId String
  modulo    String  // alunos, cursos, matriculas, baixas, certificados, salas, aulas
  ativo     Boolean @default(true)

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, modulo])
  @@map("empresa_modulos")
}

// ─── Salas WebRTC ──────────────────────────────────────
model Sala {
  id              String   @id @default(cuid())
  nome            String
  codigo          String   @unique
  empresaId       String?
  criadoPorId     String
  maxParticipantes Int     @default(10)
  ativa           Boolean  @default(true)
  createdAt       DateTime @default(now())

  empresa    Empresa?    @relation(fields: [empresaId], references: [id])
  criadoPor  User        @relation(fields: [criadoPorId], references: [id])
  signal     SalaSignal?

  @@map("salas")
}

// ─── Sinalização WebRTC (HTTP polling) ────────────────
model SalaSignal {
  id         String   @id @default(cuid())
  salaId     String   @unique
  offer      String?  @db.Text
  answer     String?  @db.Text
  callerName String?
  calleeName String?
  iceCaller  String   @default("[]") @db.Text
  iceCallee  String   @default("[]") @db.Text
  updatedAt  DateTime @updatedAt

  sala Sala @relation(fields: [salaId], references: [id], onDelete: Cascade)

  @@map("sala_signals")
}

// ─── Cursos por empresa ────────────────────────────────
model EmpCurso {
  id           String  @id @default(cuid())
  empresaId    String
  nome         String
  descricao    String?
  cargaHoraria Int?
  ativo        Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  empresa      Empresa      @relation(fields: [empresaId], references: [id])
  modulos      Modulo[]
  matriculas   Matricula[]
  certificados Certificado[]

  @@map("emp_cursos")
}

// ─── Módulos ───────────────────────────────────────────
model Modulo {
  id          String   @id @default(cuid())
  empCursoId  String
  nome        String
  descricao   String?
  ordem       Int      @default(0)
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())

  empCurso EmpCurso @relation(fields: [empCursoId], references: [id])
  aulas    Aula[]

  @@map("modulos")
}

// ─── Aulas ────────────────────────────────────────────
model Aula {
  id        String   @id @default(cuid())
  moduloId  String
  nome      String
  tipo      String   @default("video") // video, online, texto, pdf
  duracao   Int?     // em minutos
  url       String?
  ordem     Int      @default(0)
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())

  modulo     Modulo          @relation(fields: [moduloId], references: [id])
  andamentos AlunoAndamento[]

  @@map("aulas")
}

// ─── Alunos ───────────────────────────────────────────
model Aluno {
  id        String    @id @default(cuid())
  empresaId String?   // Aluno pertence a uma empresa específica (como pref_contribuinte)
  nome      String
  email     String
  cpf       String?
  telefone  String?
  dataNasc  DateTime?
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  empresa      Empresa?      @relation(fields: [empresaId], references: [id])
  matriculas   Matricula[]
  certificados Certificado[]

  // Unicidade por empresa — quando empresaId for NULL usa email global por compatibilidade
  @@unique([empresaId, email])
  @@unique([empresaId, cpf])
  @@map("alunos")
}

// ─── Matrículas ───────────────────────────────────────
model Matricula {
  id         String   @id @default(cuid())
  alunoId    String
  empCursoId String
  status     String   @default("ativa") // ativa, concluida, cancelada
  dataInicio DateTime @default(now())
  dataFim    DateTime?
  valor      Decimal  @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  aluno      Aluno          @relation(fields: [alunoId], references: [id])
  empCurso   EmpCurso       @relation(fields: [empCursoId], references: [id])
  andamentos AlunoAndamento[]
  baixas     Baixa[]

  @@map("matriculas")
}

// ─── Andamento dos alunos ─────────────────────────────
model AlunoAndamento {
  id          String    @id @default(cuid())
  matriculaId String
  aulaId      String
  concluida   Boolean   @default(false)
  dataConc    DateTime?
  createdAt   DateTime  @default(now())

  matricula Matricula @relation(fields: [matriculaId], references: [id])
  aula      Aula      @relation(fields: [aulaId], references: [id])

  @@unique([matriculaId, aulaId])
  @@map("alunos_andamento")
}

// ─── Baixas financeiras ───────────────────────────────
model Baixa {
  id          String   @id @default(cuid())
  matriculaId String?
  descricao   String?
  valor       Decimal  @db.Decimal(10, 2)
  tipo        String   @default("mensalidade") // mensalidade, matricula, certificado, outros
  status      String   @default("pendente")    // pago, pendente, cancelado
  dataPag     DateTime?
  dataVenc    DateTime?
  createdAt   DateTime @default(now())

  matricula Matricula? @relation(fields: [matriculaId], references: [id])

  @@map("baixas")
}

// ─── Certificados ─────────────────────────────────────
model Certificado {
  id          String   @id @default(cuid())
  alunoId     String
  empCursoId  String
  codigo      String   @unique @default(cuid())
  dataEmissao DateTime @default(now())

  aluno    Aluno    @relation(fields: [alunoId], references: [id])
  empCurso EmpCurso @relation(fields: [empCursoId], references: [id])

  @@map("certificados")
}

// ─── Auditoria de segurança ───────────────────────────
model SegurancaUser {
  id        String   @id @default(cuid())
  userId    String
  acao      String   // login, logout, create_user, edit_user, etc.
  detalhes  String?
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("seguranca_user")
}
