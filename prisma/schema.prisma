// =============================================================================
// ESQUEMA DO BANCO DE DADOS — StackSystems
// =============================================================================
// Banco: PostgreSQL (Neon serverless)
// ORM:   Prisma v5
//
// Convenções:
//   - Todos os nomes de campos estão em português
//   - Toda tabela multi-tenant contém o campo empresaId
//   - Campos criadoEm / atualizadoEm substituem createdAt / updatedAt
//
// Para aplicar mudanças ao banco:
//   npx prisma db push
//
// Para abrir o painel visual do banco:
//   npm run db:studio
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// PAPEL DO USUÁRIO (papel = role)
// A = Administrador da empresa — acesso total à própria empresa
// T = Técnico               — acesso conforme permissões do grupo/setor
// F = Docente (Corpo Docente) — acesso restrito (alunos, aulas)
// ---------------------------------------------------------------------------
enum PapelUsuario {
  A // Administrador
  T // Técnico
  F // Docente
}

// ===========================================================================
// AUTENTICAÇÃO — Usuários internos do sistema
// ===========================================================================

model Usuario {
  id           String      @id @default(cuid())
  nome         String
  email        String      @unique
  senha        String
  papel        PapelUsuario @default(F)
  superAdmin   Boolean     @default(false) // Apenas desenvolvedor/i3 — acesso a todas as empresas
  departamento String?
  telefone     String?
  avatar       String?
  ativo        Boolean     @default(true)
  empresaId    String?
  setorId      String?
  grupoId      String?
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt

  // Relacionamentos
  empresa       Empresa?        @relation(fields: [empresaId],  references: [id])
  setor         Setor?          @relation(fields: [setorId],    references: [id])
  grupo         Grupo?          @relation(fields: [grupoId],    references: [id])
  accounts      Account[]
  sessions      Session[]
  logsSeguranca SegurancaUsuario[]
  salasCreadas  Sala[]
  permissoes    PermissaoUsuario[]

  @@map("usuarios")
}

// ---------------------------------------------------------------------------
// Account / Session / VerificationToken
// Mantidos em inglês — NextAuth.js exige esses nomes exatos de campo
// ---------------------------------------------------------------------------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===========================================================================
// EMPRESA — Tenant principal do sistema (≡ prefeituras no i3 SCMWeb)
// ===========================================================================
model Empresa {
  id          String   @id @default(cuid())

  // Identificação
  nome        String
  sigla       String?
  cnpj        String?  @unique

  // Contato
  email       String?
  telefone    String?
  fax         String?
  site        String?

  // Endereço
  endereco    String?
  bairro      String?
  cep         String?
  municipio   String?
  uf          String?
  latitude    String?
  longitude   String?

  // Identidade visual
  cor         String?  // Cor primária (hex)
  cor2        String?  // Cor secundária (hex)
  logo        String?  // URL da logomarca
  brasao      String?  // URL do brasão/ícone
  banner      String?  // URL do banner/capa

  // Configuração do sistema
  nomeSistema String?  // Ex: "Portal SEMEDUC"
  tipoSistema String?  // escola | treinamento | consultoria | clinica | personalizado
  mascara     String?  // Máscara de numeração ex: ###/AAAA
  descricao   String?
  anuncios    String?  // JSON: [{titulo, texto, cor}]
  ativa       Boolean  @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relacionamentos
  cursos      CursoDaEmpresa[]
  usuarios    Usuario[]
  alunos      Aluno[]
  modulos     ModuloDaEmpresa[]
  salas       Sala[]
  setores     Setor[]
  grupos      Grupo[]
  permissoes  PermissaoUsuario[]

  @@map("empresas")
}

// ===========================================================================
// SETORES — Departamentos da empresa (≡ secretarias/deptos no i3)
// ===========================================================================
model Setor {
  id        String   @id @default(cuid())
  empresaId String
  nome      String
  descricao String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresa  Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  modulos  SetorModulo[]
  usuarios Usuario[]

  @@unique([empresaId, nome])
  @@map("setores")
}

// Módulos liberados para um setor
model SetorModulo {
  setorId String
  modulo  String // alunos, cursos, matriculas, etc.

  setor Setor @relation(fields: [setorId], references: [id], onDelete: Cascade)

  @@id([setorId, modulo])
  @@map("setor_modulos")
}

// ===========================================================================
// GRUPOS — Grupos de usuários dentro da empresa (≡ user_menus no i3)
// ===========================================================================
model Grupo {
  id           String   @id @default(cuid())
  empresaId    String
  nome         String
  descricao    String?
  isAdmin      Boolean  @default(false) // Admin do grupo: acesso completo aos módulos da empresa
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresa    Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  modulos    GrupoModulo[]
  usuarios   Usuario[]
  permissoes PermissaoUsuario[]

  @@unique([empresaId, nome])
  @@map("grupos")
}

// Módulos liberados para um grupo
model GrupoModulo {
  grupoId String
  modulo  String

  grupo Grupo @relation(fields: [grupoId], references: [id], onDelete: Cascade)

  @@id([grupoId, modulo])
  @@map("grupo_modulos")
}

// ===========================================================================
// MÓDULOS POR EMPRESA — Quais módulos cada empresa tem ativados
// (≡ pref_sistemas no i3)
// ===========================================================================
model ModuloDaEmpresa {
  id        String  @id @default(cuid())
  empresaId String
  modulo    String  // alunos, cursos, matriculas, baixas, certificados, salas, aulas
  ativo     Boolean @default(true)

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, modulo])
  @@map("modulos_da_empresa")
}

// ===========================================================================
// PERMISSÕES GRANULARES — CRUD por módulo por usuário/grupo
// (≡ user_seguranca no i3 SCMWeb)
// Resolução: permissão do usuário individual tem prioridade sobre o grupo.
// superAdmin / papel A / grupoIsAdmin = acesso total (não consultado).
// ===========================================================================
model PermissaoUsuario {
  id        String   @id @default(cuid())
  empresaId String
  usuarioId String?  // Permissão individual (sobrepõe grupo)
  grupoId   String?  // Permissão por grupo (fallback)
  modulo    String   // alunos, cursos, salas, matriculas, baixas, etc.
  podeLer   Boolean  @default(true)
  podeCriar Boolean  @default(false)
  podeEditar Boolean @default(false)
  podeDeletar Boolean @default(false)
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresa  Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario  Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  grupo    Grupo?   @relation(fields: [grupoId],   references: [id], onDelete: Cascade)

  // Um registro por combinação usuário+módulo+empresa
  @@unique([empresaId, usuarioId, modulo])
  // Um registro por combinação grupo+módulo+empresa
  @@unique([empresaId, grupoId, modulo])
  @@map("permissoes_usuario")
}

// ===========================================================================
// SALAS — Salas de videoaula (WebRTC)
// ===========================================================================
model Sala {
  id               String   @id @default(cuid())
  nome             String
  codigo           String   @unique // Código de acesso ex: ABC123
  empresaId        String?
  criadoPorId      String
  maxParticipantes Int      @default(10)
  ativa            Boolean  @default(true)
  criadoEm         DateTime @default(now())

  empresa   Empresa?    @relation(fields: [empresaId], references: [id])
  criadoPor Usuario     @relation(fields: [criadoPorId], references: [id])
  sinal     SinalSala?

  @@map("salas")
}

// Sinalização WebRTC via HTTP polling (offer/answer/ICE candidates)
model SinalSala {
  id         String   @id @default(cuid())
  salaId     String   @unique
  offer      String?  @db.Text
  answer     String?  @db.Text
  nomeCaller String?
  nomeCallee String?
  iceCaller  String   @default("[]") @db.Text
  iceCallee  String   @default("[]") @db.Text
  atualizadoEm DateTime @updatedAt

  sala Sala @relation(fields: [salaId], references: [id], onDelete: Cascade)

  @@map("sinais_sala")
}

// ===========================================================================
// CURSOS — Cursos oferecidos pela empresa
// ===========================================================================
model CursoDaEmpresa {
  id           String   @id @default(cuid())
  empresaId    String
  nome         String
  descricao    String?
  cargaHoraria Int?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresa      Empresa       @relation(fields: [empresaId], references: [id])
  modulos      ModuloCurso[]
  matriculas   Matricula[]
  certificados Certificado[]

  @@map("cursos_da_empresa")
}

// Módulos/capítulos do curso
model ModuloCurso {
  id         String   @id @default(cuid())
  cursoId    String
  nome       String
  descricao  String?
  ordem      Int      @default(0)
  ativo      Boolean  @default(true)
  criadoEm   DateTime @default(now())

  curso  CursoDaEmpresa @relation(fields: [cursoId], references: [id])
  aulas  Aula[]

  @@map("modulos_curso")
}

// Aulas dentro de um módulo
model Aula {
  id        String   @id @default(cuid())
  moduloId  String
  nome      String
  tipo      String   @default("video") // video, online, texto, pdf
  duracao   Int?     // Em minutos
  url       String?
  ordem     Int      @default(0)
  ativa     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  modulo     ModuloCurso     @relation(fields: [moduloId], references: [id])
  andamentos AlunoAndamento[]

  @@map("aulas")
}

// ===========================================================================
// ALUNOS — Pessoas matriculadas em cursos da empresa
// ===========================================================================
model Aluno {
  id        String    @id @default(cuid())
  empresaId String?
  nome      String
  email     String
  cpf       String?
  telefone  String?
  dataNasc  DateTime?
  ativo     Boolean   @default(true)
  criadoEm  DateTime  @default(now())
  atualizadoEm DateTime @updatedAt

  empresa      Empresa?      @relation(fields: [empresaId], references: [id])
  matriculas   Matricula[]
  certificados Certificado[]

  // E-mail e CPF únicos dentro da empresa
  @@unique([empresaId, email])
  @@unique([empresaId, cpf])
  @@map("alunos")
}

// ===========================================================================
// MATRÍCULAS — Vínculo aluno ↔ curso
// ===========================================================================
model Matricula {
  id         String   @id @default(cuid())
  alunoId    String
  cursoId    String
  status     String   @default("ativa")    // ativa, concluida, cancelada
  dataInicio DateTime @default(now())
  dataFim    DateTime?
  valor      Decimal  @default(0) @db.Decimal(10, 2)
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  aluno      Aluno           @relation(fields: [alunoId],  references: [id])
  curso      CursoDaEmpresa  @relation(fields: [cursoId],  references: [id])
  andamentos AlunoAndamento[]
  baixas     Baixa[]

  @@map("matriculas")
}

// Progresso do aluno por aula
model AlunoAndamento {
  id          String    @id @default(cuid())
  matriculaId String
  aulaId      String
  concluida   Boolean   @default(false)
  dataConclusao DateTime?
  criadoEm    DateTime  @default(now())

  matricula Matricula @relation(fields: [matriculaId], references: [id])
  aula      Aula      @relation(fields: [aulaId],      references: [id])

  @@unique([matriculaId, aulaId])
  @@map("alunos_andamento")
}

// ===========================================================================
// BAIXAS FINANCEIRAS — Cobranças e pagamentos de matrículas
// ===========================================================================
model Baixa {
  id          String   @id @default(cuid())
  matriculaId String?
  descricao   String?
  valor       Decimal  @db.Decimal(10, 2)
  tipo        String   @default("mensalidade") // mensalidade, matricula, certificado, outros
  status      String   @default("pendente")    // pago, pendente, cancelado
  dataPagamento DateTime?
  dataVencimento DateTime?
  criadoEm    DateTime @default(now())

  matricula Matricula? @relation(fields: [matriculaId], references: [id])

  @@map("baixas")
}

// ===========================================================================
// CERTIFICADOS — Emitidos ao concluir um curso
// ===========================================================================
model Certificado {
  id          String   @id @default(cuid())
  alunoId     String
  cursoId     String
  codigo      String   @unique @default(cuid())
  dataEmissao DateTime @default(now())

  aluno  Aluno          @relation(fields: [alunoId],  references: [id])
  curso  CursoDaEmpresa @relation(fields: [cursoId],  references: [id])

  @@map("certificados")
}

// ===========================================================================
// AUDITORIA DE SEGURANÇA — Log de ações dos usuários
// ===========================================================================
model SegurancaUsuario {
  id        String   @id @default(cuid())
  usuarioId String
  acao      String   // login, logout, criar_usuario, editar_usuario, etc.
  detalhes  String?
  ip        String?
  criadoEm  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("seguranca_usuario")
}
